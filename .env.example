# FluentDB server configuration
# Port for the local server (UI + API)
FLUENTDB_PORT=4983

# Data directory (connections, query history). Default: ~/.fluentdb
# FLUENTDB_DATA_DIR=/path/to/dir

# Encryption key override for the credentials store (hex, 32 bytes).
# By default a key file is created at <data dir>/key with mode 0600.
# FLUENTDB_SECRET=

# AI assistant — Google Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Docker socket override (defaults to /var/run/docker.sock or $DOCKER_HOST)
# DOCKER_HOST=
